{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PBB Landing Kit install config",
  "type": "object",
  "required": ["schema_version", "mode", "app"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "mode": {
      "type": "string",
      "enum": ["preflight", "fresh", "repair", "upgrade"]
    },
    "kit": {
      "type": "object",
      "properties": {
        "run_id": { "type": "string" },
        "timezone": { "type": "string" }
      },
      "additionalProperties": true
    },
    "app": {
      "type": "object",
      "required": ["install_path"],
      "properties": {
        "install_path": { "type": "string", "minLength": 1 },
        "public_path": { "type": "string" },
        "app_url": { "type": "string" },
        "app_env": { "type": "string" },
        "app_debug": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "landing": {
      "type": "object",
      "properties": {
        "local_host": { "type": "string", "default": "pbb.ph" },
        "hq_host": { "type": "string", "default": "hub.pbb.ph" },
        "registry_token_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "paths": {
          "type": "object",
          "properties": {
            "registry": { "type": "string" },
            "audit_log": { "type": "string" },
            "gateway_log": { "type": "string" },
            "relay_hub_json": {
              "type": "string",
              "description": "Relay hub.json source. Prefer https://relay.pbb.ph/hub.json so Relay may run on another machine; local absolute file paths are still supported for co-located installs."
            }
          },
          "additionalProperties": false
        },
        "gateway": {
          "type": "object",
          "properties": {
            "max_body_bytes": { "type": "integer", "minimum": 1 },
            "require_peer_domain": { "type": "boolean" },
            "ca_bundle": {
              "type": "string",
              "description": "Optional CA bundle path for PHP cURL. Required when relay_hub_json is an HTTPS source using the local PBB certificate chain, for example C:/wamp64/certs/pbb.ph/pbb.ph.fullchain.crt."
            },
            "timeout_seconds": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
